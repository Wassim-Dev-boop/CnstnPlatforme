{
  "realm": "cnstn-intranet",
  "enabled": true,
  "displayName": "CNSTN Intranet",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "registrationEmailAsUsername": false,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 28800,
  "clientSessionIdleTimeout": 1800,
  "clientSessionMaxLifespan": 28800,
  "roles": {
    "realm": [
      {
        "name": "ADMIN"
      },
      {
        "name": "EMPLOYE"
      },
      {
        "name": "CHEF_HIERARCHIQUE"
      },
      {
        "name": "RESPONSABLE_SALLE"
      },
      {
        "name": "RESPONSABLE_SECURITE"
      },
      {
        "name": "DIRECTEUR_DSN"
      },
      {
        "name": "RESPONSABLE_QUALITE"
      },
      {
        "name": "RESPONSABLE_IT"
      }
    ]
  },
  "clients": [
    {
      "clientId": "cnstn-frontend-spa",
      "name": "CNSTN Frontend SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://127.0.0.1:4200/*",
        "http://host.docker.internal:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://127.0.0.1:4200",
        "http://host.docker.internal:4200"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "id.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "cnstn-api-gateway",
      "name": "CNSTN API Gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "gateway-secret",
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "id.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "cnstn-admin-cli",
      "name": "CNSTN Admin Service Client",
      "enabled": true,
      "publicClient": false,
      "secret": "admin-cli-secret",
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "cnstn-postman",
      "name": "CNSTN Postman Client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "directAccessGrantsEnabled": true,
      "webOrigins": [
        "http://localhost:4200",
        "http://127.0.0.1:4200",
        "http://host.docker.internal:4200"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "id.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
